# SITE_ADDRESS from .env:
#   a real hostname (e.g. jwst.example.org) -> automatic HTTPS via Let's Encrypt
#   ":80"                                   -> plain HTTP (testing / SSH tunnel only)
{$SITE_ADDRESS}

basic_auth {
    {$BASIC_AUTH_USER} {$BASIC_AUTH_HASH}
}

# Streamlit (incl. its WebSocket) proxies cleanly with defaults.
reverse_proxy app:8501
