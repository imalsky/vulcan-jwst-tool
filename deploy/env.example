# Copy to .env (same directory as docker-compose.yml) and edit.

# Hostname for automatic HTTPS, or ":80" for plain HTTP while testing.
SITE_ADDRESS=:80

# Basic-auth gate in front of the GUI. Generate the hash on the server with:
#   sudo docker run --rm caddy:2 caddy hash-password --plaintext 'CHOOSE-A-PASSWORD'
# Paste the $2a$... output below EXACTLY as printed (no quotes needed; this
# file is read with env_file, which does not interpolate $).
BASIC_AUTH_USER=vulcan
BASIC_AUTH_HASH=REPLACE_WITH_HASH_OUTPUT
